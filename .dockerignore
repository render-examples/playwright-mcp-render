# The Render wrapper (Dockerfile.render) only needs render-entrypoint.sh, so keep
# the build context tiny. This file applies to every build using this context,
# including the upstream Dockerfile — but that build is unaffected in practice: it
# reinstalls deps via `npm ci` and copies only root files (none of these paths).
node_modules/
.git/
.github/
.devcontainer/
.claude/
tests/
test-results/
playwright-report/
sessions/
.env
*.log
.DS_Store
