# Playwright MCP configuration.
# Copy to .env for local runs (Render sets these via render.yaml / the dashboard).
# Every value below also has a CLI flag — see the README arguments table.

# Port the Streamable-HTTP / SSE MCP transport listens on (Render routes to this).
PORT=10000

# Demo mode. Leave "false" for the full server (all capabilities, no origin limits).
# Set "true" ONLY for a public demo you host yourself: it forces per-connection
# isolated in-memory sessions, blocks obvious internal origins, disables service
# workers, and tightens timeouts. See the README "Demo mode" section.
DEMO=false

# --- The following take effect only when you run the server directly (locally or
# --- in your own image). On Render, render-entrypoint.sh always passes the
# --- equivalent CLI flags, and CLI flags override these env vars — so setting them
# --- in the Render dashboard has no effect.

# Bind to all interfaces so the platform can reach the process.
PLAYWRIGHT_MCP_HOST=0.0.0.0

# Run Chromium headless — required, Render has no display.
PLAYWRIGHT_MCP_HEADLESS=true

# Disable Chromium's sandbox — required in Render's containers.
PLAYWRIGHT_MCP_NO_SANDBOX=true

# Comma-separated hosts the server may serve from ("*" disables the host check).
# Unlike the vars above, this ONE is honored on Render: the entrypoint defaults it
# to $RENDER_EXTERNAL_HOSTNAME (your onrender.com host), and setting it here or in
# the dashboard overrides that — e.g. add a custom domain: "myapp.com,myapp.onrender.com".
PLAYWRIGHT_MCP_ALLOWED_HOSTS=*
